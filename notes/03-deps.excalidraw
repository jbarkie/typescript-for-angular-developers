      "seed": 519630359,
      "version": 316,
      "versionNonce": 1559232631,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1777405019822,
      "link": null,
      "locked": false,
      "text": "\"Write enough tests that you and your team are confident in the code you are shipping\".\n\n- Bugs scale linearly with number of lines of code. (Godel's incompleteness)\n- You HAVE to test things in a meaningful way.\n    - Based on risk - \"risk based testing\".\n",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "\"Write enough tests that you and your team are confident in the code you are shipping\".\n\n- Bugs scale linearly with number of lines of code. (Godel's incompleteness)\n- You HAVE to test things in a meaningful way.\n    - Based on risk - \"risk based testing\".\n",
      "autoResize": true,
      "lineHeight": 1.25
    }
