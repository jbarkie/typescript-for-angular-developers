{
  "name": "validation-lib",
  "version": "0.0.1",
  "description": "Tiny composable validation library",
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "test:watch": "vitest",
    "typescheck": "tsc --noEmit"
  },
  "devDependencies": {
    "tsdown": "^0.21.10",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  }
}
